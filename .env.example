# Copy this file to .env and fill values before running experiments.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...

# Optional: OpenAI-compatible proxy (LiteLLM, vLLM, etc.)
# API_BASE_URL=http://localhost:8000/v1
# API_ORG_ID=your-org-id
# API_TOKEN_CMD=your-token-command

# Optional defaults
EXPERIMENT_MAX_CONCURRENT=10
EXPERIMENT_SEED=42
EXPERIMENT_RESULTS_DIR=results
